# AI provider (OpenAI is the default provider)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Storage backend
# Set to true to use the local file store (.data/ folder), false to use Firebase Firestore.
USE_LOCAL_DB=true

# Firebase Admin credentials (only required if USE_LOCAL_DB=false)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Redis cache (falls back to an in-memory store if not provided)
REDIS_URL=redis://localhost:6379
